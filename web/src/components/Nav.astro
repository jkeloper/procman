---
import { site } from '~/config/site';
---

<header class="w-full">
  <div class="container-x flex items-center justify-between py-5">
    <a href="/" class="flex items-center gap-2 group">
      <img src="/icon.webp" alt="procman" width="28" height="28" class="rounded-md" />
      <span class="font-semibold tracking-tight text-lg">{site.name}</span>
      <span class="badge text-[var(--muted)] hidden sm:inline-flex">v{site.version}</span>
    </a>
    <nav class="flex items-center gap-1 sm:gap-2 text-sm">
      <a href="#features" class="btn btn-ghost px-3 py-2 hidden sm:inline-flex">Features</a>
      <a href="#install" class="btn btn-ghost px-3 py-2 hidden sm:inline-flex">Install</a>
      <a href={site.githubUrl} class="btn btn-ghost px-3 py-2" target="_blank" rel="noreferrer">GitHub</a>
      <a href={site.downloadUrl} class="btn btn-primary">Download</a>
    </nav>
  </div>
</header>
