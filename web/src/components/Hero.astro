---
import { site } from '~/config/site';
---

<section class="container-x pt-10 sm:pt-16 pb-16 sm:pb-24 text-center">
  <div class="flex justify-center mb-6 fade-in">
    <div class="relative">
      <div class="absolute inset-0 blur-3xl opacity-60 bg-forest-500/40 rounded-full"></div>
      <img
        src="/icon.png"
        alt="procman frog logo"
        width="112"
        height="112"
        class="relative rounded-3xl shadow-xl"
      />
    </div>
  </div>

  <h1 class="fade-in text-4xl sm:text-6xl font-semibold tracking-tight leading-[1.05] mb-5">
    <span class="block">{site.name} &mdash; Local Mission Control</span>
    <span class="block text-[var(--muted)] font-medium text-2xl sm:text-3xl mt-3">for macOS</span>
  </h1>

  <p class="fade-in mx-auto max-w-2xl text-base sm:text-lg text-[var(--muted)] leading-relaxed">
    {site.description}
  </p>

  <div class="fade-in mt-8 flex flex-col sm:flex-row gap-3 items-center justify-center">
    <a class="btn btn-primary w-full sm:w-auto" href={site.downloadUrl}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 3v12"/><path d="m6 9 6 6 6-6"/><path d="M5 21h14"/>
      </svg>
      Download for macOS
    </a>
    <a class="btn btn-ghost w-full sm:w-auto" href={site.githubUrl} target="_blank" rel="noreferrer">
      View on GitHub
    </a>
  </div>

  <p class="fade-in mt-5 text-xs text-[var(--muted)]">
    Requires macOS {site.minMacOS}+ (Apple Silicon). Signed &amp; notarized. Auto-updates via GitHub Releases.
  </p>
</section>
