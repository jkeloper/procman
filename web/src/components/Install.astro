---
import { site } from '~/config/site';
---

<section id="install" class="container-x py-16 sm:py-24">
  <div class="text-center mb-10 fade-in">
    <span class="badge mb-4">Install</span>
    <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight">
      Two ways to get started
    </h2>
    <p class="mt-3 text-[var(--muted)] max-w-xl mx-auto">
      Grab the signed DMG, or build from source if you like living dangerously.
    </p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4" data-install-tabs>
    <div class="card fade-in">
      <div class="flex items-center justify-between mb-3">
        <div class="flex items-center gap-2">
          <span class="badge" style="background: color-mix(in oklab, var(--accent) 14%, transparent);">Recommended</span>
          <h3 class="font-semibold text-lg">DMG Download</h3>
        </div>
        <span class="text-xs text-[var(--muted)]">v{site.version}</span>
      </div>
      <ol class="space-y-2 text-sm text-[var(--muted)] leading-relaxed list-decimal pl-5">
        <li>Download the <code class="text-[var(--fg)]">procman_{site.version}_aarch64.dmg</code> installer.</li>
        <li>Drag <strong>procman</strong> into <strong>Applications</strong>.</li>
        <li>First launch &mdash; no Gatekeeper warning (Developer ID signed &amp; notarized).</li>
      </ol>
      <div class="mt-5">
        <a class="btn btn-primary w-full" href={site.downloadUrl}>
          Download DMG (Apple Silicon)
        </a>
      </div>
      <p class="mt-3 text-xs text-[var(--muted)]">
        Intel Mac support is not currently shipped. File an issue if you need it.
      </p>
    </div>

    <div class="card fade-in">
      <div class="flex items-center justify-between mb-3">
        <h3 class="font-semibold text-lg">From source</h3>
        <span class="text-xs text-[var(--muted)]">Rust + Node</span>
      </div>
      <pre class="code"><code>{`git clone ${site.githubUrl}.git
cd procman
./scripts/install.sh`}</code></pre>
      <p class="mt-3 text-xs text-[var(--muted)]">
        The script installs dependencies, runs the Rust test suite, and builds an unsigned local DMG.
      </p>
    </div>
  </div>

  <div class="mt-8 card fade-in">
    <div class="flex items-start gap-3">
      <div class="w-9 h-9 shrink-0 rounded-lg flex items-center justify-center text-lg"
           style="background: color-mix(in oklab, var(--accent) 18%, transparent); color: var(--accent);">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/><path d="M3 21v-5h5"/>
        </svg>
      </div>
      <div>
        <h4 class="font-semibold mb-1">Auto-updates</h4>
        <p class="text-sm text-[var(--muted)] leading-relaxed">
          procman checks GitHub Releases on launch and silently downloads the next version.
          You&rsquo;ll see a subtle banner; click to restart whenever you&rsquo;re ready.
        </p>
      </div>
    </div>
  </div>
</section>
